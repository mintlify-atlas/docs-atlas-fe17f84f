  "keyFeatures": [
    "Scans 60+ rules across multiple categories (state, performance, security, architecture)",
    "Automatic framework detection (Next.js, Vite, Remix, Expo, React Native)",
    "0-100 health score based on error and warning severity",
    "Dead code detection for unused files, exports, and types",
    "Diff mode to scan only changed files",
    "GitHub Actions integration with PR comments",
    "Coding agent skills for Cursor, Claude, OpenCode, and more",
    "Node.js programmatic API for custom integrations"
  ],
  "publicApiSurface": [
    "react-doctor [directory] [options]",
    "diagnose(directory, options)",
    "getDiffInfo(directory, baseBranch)",
    "filterSourceFiles(files, directory)",
    "--verbose",
    "--score",
    "--diff [base]",
    "--project <name>",
    "--fix",
    "--no-lint",
    "--no-dead-code",
    "--fail-on <level>"
  ]
}
